{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@pair/shared": ["../../packages/shared/src/index.ts"]
    },
    "outDir": "./dist",
    "noEmit": false
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "miniprogram_npm", "dist"]
}
