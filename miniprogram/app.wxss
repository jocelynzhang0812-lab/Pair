@import "./styles/tokens.wxss";

page {
  min-height: 100%;
  background: var(--pair-bg-raised);
  color: var(--pair-fg-primary);
  font-family: var(--pair-font-sans);
  --pair-page-x: 54rpx;
  --pair-page-top: 156rpx;
  --pair-page-bottom: 56rpx;
  --pair-tab-bottom: 188rpx;
  --pair-space-xs: 8rpx;
  --pair-space-sm: 12rpx;
  --pair-space-md: 16rpx;
  --pair-space-lg: 24rpx;
  --pair-space-xl: 32rpx;
  --pair-space-2xl: 56rpx;
  --pair-space-3xl: 64rpx;
  --pair-card-padding: 34rpx;
  --pair-card-radius: 28rpx;
  --pair-list-gap: 24rpx;
  --pair-section-gap: 56rpx;
  --pair-title-size: 76rpx;
  --pair-title-small-size: 58rpx;
  --pair-subtitle-size: 34rpx;
  --pair-row-title-size: 38rpx;
  --pair-card-title-size: 40rpx;
  --pair-body-size: 30rpx;
  --pair-body-small-size: 28rpx;
  --pair-caption-size: 26rpx;
  --pair-overline-size: 22rpx;
  --pair-meta-size: 24rpx;
  --pair-chip-size: 23rpx;
  --pair-card-score-size: 56rpx;
  --pair-summary-score-size: 142rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  line-height: inherit;
  font: inherit;
}

button::after {
  border: 0;
}

.screen {
  min-height: 100vh;
  padding: var(--pair-page-top) var(--pair-page-x) var(--pair-page-bottom);
  background:
    radial-gradient(circle at 50% 10%, rgba(255, 255, 255, 0.9), rgba(247, 245, 240, 0.38) 66%, rgba(247, 245, 240, 0.5)),
    var(--pair-bg-raised);
}

.screen.with-tab {
  padding-bottom: var(--pair-tab-bottom);
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 64rpx;
  margin-bottom: var(--pair-space-xl);
}

.back-button,
.icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 88rpx;
  min-height: 88rpx;
  color: var(--pair-fg-secondary);
}

.kicker {
  display: flex;
  align-items: center;
  gap: var(--pair-space-sm);
  margin-bottom: var(--pair-space-md);
  color: var(--pair-fg-secondary);
  font-size: var(--pair-meta-size);
}

.title {
  margin: 0;
  font-family: var(--pair-font-serif);
  font-size: var(--pair-title-size);
  font-weight: 700;
  line-height: 1.22;
  letter-spacing: 0;
  color: var(--pair-ink);
}

.title.small {
  font-size: var(--pair-title-small-size);
}

.subtitle {
  display: block;
  margin-top: var(--pair-space-xl);
  color: var(--pair-copy);
  font-size: var(--pair-subtitle-size);
  font-weight: 500;
  line-height: 1.7;
}

.card {
  margin-top: var(--pair-space-xl);
  padding: var(--pair-card-padding);
  border: 2rpx solid var(--pair-border-prototype);
  border-radius: var(--pair-card-radius);
  background: rgba(255, 255, 255, 0.86);
  box-shadow: none;
}

.raised {
  box-shadow: 0 10rpx 32rpx rgba(20, 18, 16, 0.035);
}

.agent-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, var(--pair-accent), var(--pair-accent-dark));
  flex: none;
}

.agent-dot.thinking {
  animation: pair-breathe 1.4s var(--pair-ease-out) infinite;
  box-shadow: 0 0 0 18rpx var(--pair-accent-glow);
}

@keyframes pair-breathe {
  0%,
  100% {
    transform: scale(1);
    opacity: 0.86;
  }

  50% {
    transform: scale(1.14);
    opacity: 1;
  }
}

.primary-button,
.secondary-button,
.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 112rpx;
  width: 100%;
  border-radius: var(--pair-card-radius);
  font-family: var(--pair-font-serif);
  font-size: var(--pair-row-title-size);
  font-weight: 700;
}

.primary-button {
  margin-top: var(--pair-space-xl);
  background: var(--pair-ink);
  color: var(--pair-fg-inverse);
  box-shadow: inset 0 0 24rpx rgba(255, 255, 255, 0.06);
}

.secondary-button {
  margin-top: var(--pair-space-lg);
  border: 2rpx solid var(--pair-fg-primary);
  background: rgba(255, 255, 255, 0.86);
  color: var(--pair-ink);
}

.ghost-button {
  margin-top: var(--pair-space-lg);
  color: var(--pair-fg-secondary);
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--pair-space-md);
  margin-top: var(--pair-space-lg);
}

.chip {
  padding: 10rpx 18rpx;
  border: 1rpx solid var(--pair-border-subtle);
  border-radius: 9999rpx;
  background: var(--pair-bg-sunken);
  color: var(--pair-fg-secondary);
  font-size: var(--pair-chip-size);
}

.chip.selected {
  border-color: var(--pair-accent);
  background: var(--pair-accent-soft);
  color: var(--pair-fg-primary);
}

.muted {
  color: var(--pair-fg-secondary);
}

.meta {
  color: var(--pair-fg-tertiary);
  font-size: var(--pair-meta-size);
}

.serif {
  font-family: var(--pair-font-serif);
}

.section-title {
  margin-top: var(--pair-section-gap);
  font-family: var(--pair-font-serif);
  font-size: var(--pair-card-title-size);
  font-weight: 700;
}

.progress-track {
  height: 12rpx;
  overflow: hidden;
  border-radius: 9999rpx;
  background: var(--pair-bg-sunken);
}

.progress-fill {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(135deg, var(--pair-accent), var(--pair-accent-dark));
}

.list {
  display: flex;
  flex-direction: column;
  gap: var(--pair-list-gap);
  margin-top: var(--pair-space-xl);
}

.person-avatar-png {
  width: 112rpx;
  height: 112rpx;
  flex: none;
}

.profile-avatar-png {
  width: 128rpx;
  height: 128rpx;
  flex: none;
}

.row {
  display: flex;
  align-items: center;
  gap: var(--pair-space-lg);
}

.row-body {
  min-width: 0;
  flex: 1;
}

.row-title {
  font-family: var(--pair-font-serif);
  font-size: var(--pair-row-title-size);
  font-weight: 700;
}

.row-subtitle {
  margin-top: var(--pair-space-xs);
  color: var(--pair-copy-strong);
  font-family: var(--pair-font-serif);
  font-size: var(--pair-body-size);
  line-height: 1.45;
}

.divider {
  height: 1rpx;
  margin: var(--pair-space-xl) 0;
  background: var(--pair-border-subtle);
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: var(--pair-space-md) var(--pair-page-x) calc(var(--pair-space-xl) + var(--pair-space-xs));
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0),
    var(--pair-bg-raised) 22%,
    var(--pair-bg-raised) 100%
  );
}

.tab-item {
  display: flex;
  min-height: 104rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: var(--pair-space-xs);
  color: var(--pair-fg-secondary);
  text-decoration: none;
}

.tab-item.active {
  color: var(--pair-ink);
}

.tab-label {
  font-family: var(--pair-font-serif);
  font-size: var(--pair-body-small-size);
  font-weight: 500;
}

.tab-item.active .tab-label {
  font-weight: 700;
}

.tab-icon {
  width: 58rpx;
  height: 58rpx;
}

.state-panel {
  display: flex;
  min-height: 520rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--pair-card-padding);
  text-align: center;
}

.state-visual {
  display: flex;
  width: 160rpx;
  height: 160rpx;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--pair-space-xl);
  border: 2rpx solid var(--pair-border-prototype);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.76);
}

.state-icon-png {
  width: 86rpx;
  height: 86rpx;
}

.state-title {
  display: block;
  font-family: var(--pair-font-serif);
  font-size: var(--pair-card-title-size);
  font-weight: 700;
  line-height: 1.35;
}

.state-copy {
  display: block;
  max-width: 520rpx;
  margin-top: var(--pair-space-md);
  color: var(--pair-fg-secondary);
  font-size: var(--pair-body-small-size);
  line-height: 1.65;
}

.state-actions {
  display: flex;
  width: 100%;
  flex-direction: column;
  margin-top: var(--pair-space-xl);
}

.inline-error {
  display: block;
  margin-top: var(--pair-space-sm);
  color: var(--pair-danger);
  font-size: var(--pair-caption-size);
  line-height: 1.45;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  margin-top: var(--pair-space-sm);
  padding: 8rpx 16rpx;
  border: 1rpx solid var(--pair-border-subtle);
  border-radius: 9999rpx;
  background: var(--pair-bg-sunken);
  color: var(--pair-fg-secondary);
  font-size: var(--pair-chip-size);
  line-height: 1.2;
}

.status-pill.completed {
  border-color: var(--pair-accent-soft);
  background: var(--pair-accent-soft);
  color: var(--pair-accent-dark);
}

.status-pill.running {
  border-color: var(--pair-accent-soft);
  background: rgba(245, 232, 216, 0.48);
  color: var(--pair-accent-dark);
}

.status-pill.failed {
  border-color: rgba(183, 69, 47, 0.18);
  background: rgba(183, 69, 47, 0.08);
  color: var(--pair-danger);
}
