.progress-card {
  padding: var(--pair-space-lg);
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: var(--pair-list-gap);
  margin-top: var(--pair-space-xl);
}

.message-card {
  padding: var(--pair-card-padding);
  border: 1rpx solid var(--pair-border-subtle);
  border-radius: 30rpx;
  background: var(--pair-bg-raised);
}

.message-card.mine {
  background: var(--pair-accent-soft);
}

.message-speaker,
.message-content {
  display: block;
}

.message-speaker {
  color: var(--pair-fg-tertiary);
  font-size: var(--pair-chip-size);
}

.message-content {
  margin-top: var(--pair-space-sm);
  font-family: var(--pair-font-serif);
  font-size: var(--pair-body-size);
  line-height: 1.6;
}

.compact-state {
  min-height: 420rpx;
}
