.agent-status {
  display: flex;
  align-items: center;
  gap: var(--pair-space-md);
  color: var(--pair-fg-secondary);
  font-size: var(--pair-body-small-size);
}

.card-stack-wrap {
  position: relative;
  margin-top: var(--pair-space-xl);
  height: 710rpx;
}

.stack-card,
.match-card {
  width: 100%;
}

.stack-card {
  position: absolute;
  left: 20rpx;
  top: 22rpx;
  right: -4rpx;
  min-height: 600rpx;
  padding: var(--pair-card-padding);
  border: 2rpx solid var(--pair-border-prototype);
  border-radius: var(--pair-card-radius);
  background: rgba(255, 255, 255, 0.58);
  transform: scale(0.96);
}

.back-card {
  opacity: 0.72;
  pointer-events: none;
}

.swipe-area {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 710rpx;
  overflow: visible;
}

.swipe-card {
  width: 100%;
  height: 710rpx;
}

.match-card {
  min-height: 640rpx;
  margin-top: 0;
  background: rgba(255, 255, 255, 0.94);
}

.match-head {
  display: flex;
  align-items: center;
  gap: var(--pair-space-lg);
}

.match-name {
  display: block;
  font-family: var(--pair-font-serif);
  font-size: var(--pair-card-title-size);
  font-weight: 700;
}

.score {
  color: var(--pair-accent-dark);
  font-family: var(--pair-font-serif);
  font-size: var(--pair-card-score-size);
  font-weight: 700;
}

.why-block,
.draft-block {
  margin-top: var(--pair-space-xl);
  padding-top: var(--pair-space-xl);
  border-top: 1rpx solid var(--pair-border-subtle);
}

.block-label,
.block-copy,
.draft-copy {
  display: block;
}

.block-label {
  color: var(--pair-fg-tertiary);
  font-size: var(--pair-overline-size);
  text-transform: uppercase;
}

.block-copy {
  margin-top: var(--pair-space-sm);
  color: var(--pair-fg-secondary);
  font-size: var(--pair-body-small-size);
  line-height: 1.6;
}

.draft-copy {
  margin-top: var(--pair-space-sm);
  font-size: var(--pair-body-size);
  line-height: 1.6;
}

.action-row {
  display: flex;
  gap: var(--pair-space-md);
  margin-top: var(--pair-space-xl);
}

.small-primary,
.small-secondary,
.small-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  border-radius: 20rpx;
  font-size: var(--pair-body-small-size);
  font-weight: 600;
}

.small-primary {
  flex: 1.15;
  background: var(--pair-fg-primary);
  color: var(--pair-fg-inverse);
}

.small-secondary {
  flex: 1;
  border: 1rpx solid var(--pair-border-default);
  background: var(--pair-bg-raised);
}

.small-ghost {
  width: 120rpx;
  color: var(--pair-fg-secondary);
}

.shelf {
  margin-top: var(--pair-section-gap);
}

.shelf-title-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--pair-space-md);
}

.shelf-title {
  margin-top: 0;
}

.shelf-hint {
  color: var(--pair-fg-tertiary);
  font-size: var(--pair-meta-size);
}

.shelf-empty {
  display: flex;
  align-items: center;
  min-height: 116rpx;
  margin-top: var(--pair-space-lg);
  padding: 0 var(--pair-card-padding);
  border: 2rpx dashed var(--pair-border-subtle);
  border-radius: var(--pair-card-radius);
  color: var(--pair-fg-tertiary);
  font-size: var(--pair-caption-size);
}

.shelf-scroll {
  width: 100%;
  margin-top: var(--pair-space-lg);
  white-space: nowrap;
}

.shelf-track {
  display: inline-flex;
  gap: var(--pair-space-md);
  padding-right: var(--pair-page-x);
}

.shelf-item {
  display: flex;
  align-items: center;
  gap: var(--pair-space-sm);
  min-width: 188rpx;
  height: 112rpx;
  padding: 14rpx 18rpx;
  border: 2rpx solid var(--pair-border-prototype);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.9);
}

.shelf-avatar {
  width: 70rpx;
  height: 70rpx;
  flex: none;
}

.shelf-name {
  max-width: 100rpx;
  overflow: hidden;
  color: var(--pair-fg-primary);
  font-family: var(--pair-font-serif);
  font-size: var(--pair-caption-size);
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.drawer-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: flex-end;
  background: rgba(20, 18, 16, 0.32);
}

.drawer-sheet {
  width: 100%;
  max-height: 86vh;
  overflow-y: auto;
  padding: var(--pair-space-lg) var(--pair-card-padding) var(--pair-space-2xl);
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  background: var(--pair-bg-raised);
  box-shadow: var(--pair-shadow-elevated);
  animation: drawer-rise 260ms var(--pair-ease-out);
}

.drawer-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto var(--pair-space-lg);
  border-radius: 9999rpx;
  background: var(--pair-border-default);
}

.drawer-sheet .state-actions {
  margin-top: var(--pair-space-2xl);
}

@keyframes drawer-rise {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
