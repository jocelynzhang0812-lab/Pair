.login-screen {
  display: flex;
  flex-direction: column;
}

.hero-visual {
  order: 2;
  height: 370rpx;
  margin-top: var(--pair-space-3xl);
}

.prototype-hero-image {
  width: 100%;
  height: 370rpx;
}

.title-block {
  order: 1;
}

.login-caption {
  display: block;
  order: 3;
  margin: var(--pair-space-xl) 0 calc(var(--pair-space-3xl) + var(--pair-space-lg));
  color: var(--pair-fg-secondary);
  font-size: var(--pair-card-title-size);
  line-height: 1.45;
}

.primary-button {
  order: 4;
}

.secondary-button {
  order: 5;
}

.ghost-button {
  order: 6;
  margin-top: var(--pair-space-xl);
}
