<view class="screen with-tab">
  <text class="title small">My Connections</text>

  <view class="segmented">
    <button
      wx:for="{{tabs}}"
      wx:key="*this"
      class="segment {{activeTab === item ? 'active' : ''}}"
      data-tab="{{item}}"
      bindtap="selectTab"
    >
      {{item}}
    </button>
  </view>

  <view wx:if="{{pageState === 'loading'}}" class="state-panel card">
    <view class="state-visual">
      <view class="agent-dot thinking"></view>
    </view>
    <text class="state-title">正在同步你的 Connections</text>
    <text class="state-copy">Pair 会把已完成、进行中和潜在连接分开，方便你回来继续。</text>
  </view>

  <view wx:elif="{{pageState === 'empty'}}" class="state-panel card">
    <view class="state-visual">
      <image class="state-icon-png" src="/assets/prototype/tab-people.png" mode="aspectFit"></image>
    </view>
    <text class="state-title">还没有建立连接</text>
    <text class="state-copy">先从 Today 发出一张卡片，等 Agent 对齐完成后会出现在这里。</text>
    <view class="state-actions">
      <button class="primary-button" bindtap="findMore">去 Today 看看</button>
    </view>
  </view>

  <view wx:elif="{{pageState === 'error' || pageState === 'failed'}}" class="state-panel card">
    <view class="state-visual">
      <view class="agent-dot"></view>
    </view>
    <text class="state-title">Connections 暂时没同步好</text>
    <text class="state-copy">已保存的连接不会丢失，稍后刷新即可。</text>
    <view class="state-actions">
      <button class="primary-button" bindtap="retryPeople">重试</button>
    </view>
  </view>

  <view wx:else class="list">
    <view
      wx:for="{{visiblePeople}}"
      wx:key="id"
      class="card person-card"
      data-id="{{item.id}}"
      data-session="{{item.sessionId}}"
      data-summary="{{item.summaryId}}"
      bindtap="openPerson"
    >
      <view class="row">
        <image class="person-avatar-png" src="{{item.avatarSrc}}" mode="aspectFit"></image>
        <view class="row-body">
          <text class="row-title">{{item.name}}</text>
          <text class="row-subtitle">{{item.headline}}</text>
          <text class="status-pill {{item.statusKind}}">{{item.status}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{detailVisible}}" class="drawer-mask" catchtap="closeMatchDetail">
    <view class="drawer-sheet" catchtap="noop">
      <view class="drawer-handle"></view>
      <view class="row">
        <image class="person-avatar-png" src="{{detailMatch.avatarSrc}}" mode="aspectFit"></image>
        <view class="row-body">
          <text class="row-title">{{detailMatch.name}}</text>
          <text class="row-subtitle">{{detailMatch.headline}}</text>
        </view>
      </view>

      <view class="why-block">
        <text class="block-label">Why ta</text>
        <text class="block-copy">{{detailMatch.whyMatch}}</text>
      </view>

      <view class="draft-block">
        <text class="block-label">Agent drafted</text>
        <text class="draft-copy serif">“{{detailMatch.intro}}”</text>
      </view>

      <view class="state-actions">
        <button class="primary-button" bindtap="sendInvite">发出邀请</button>
        <button class="secondary-button" bindtap="closeMatchDetail">再想想</button>
      </view>
    </view>
  </view>

  <view class="bottom-nav">
    <navigator class="tab-item" url="/pages/today/index" open-type="reLaunch">
      <image class="tab-icon" src="/assets/prototype/tab-today.png" mode="aspectFit"></image>
      <text class="tab-label">Today</text>
    </navigator>
    <navigator class="tab-item active" url="/pages/people/index" open-type="reLaunch">
      <image class="tab-icon" src="/assets/prototype/tab-people.png" mode="aspectFit"></image>
      <text class="tab-label">People</text>
    </navigator>
    <navigator class="tab-item" url="/pages/chats/index" open-type="reLaunch">
      <image class="tab-icon" src="/assets/prototype/tab-chats.png" mode="aspectFit"></image>
      <text class="tab-label">Chats</text>
    </navigator>
    <navigator class="tab-item" url="/pages/me/index" open-type="reLaunch">
      <image class="tab-icon" src="/assets/prototype/tab-me.png" mode="aspectFit"></image>
      <text class="tab-label">Me</text>
    </navigator>
  </view>
</view>
